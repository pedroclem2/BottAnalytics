# Local Postgres (matches docker/docker-compose.yml defaults)
POSTGRES_USER=bott
POSTGRES_PASSWORD=bott
POSTGRES_DB=bott_analytics
POSTGRES_PORT=5444

# Used by ETL (psycopg) and the Next.js server-side data layer (postgres.js)
DATABASE_URL=postgresql://bott:bott@localhost:5444/bott_analytics

# Path to the source workbook (defaults to repo root)
CSAT_XLSM_PATH="./Copy of Survey_Data_Model.xlsm"
